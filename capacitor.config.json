{
  "appId": "com.msmessenger.app",
  "appName": "MS Messenger",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#1a1d23"
    },
    "SplashScreen": {
      "backgroundColor": "#1a1d23",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false
    },
    "GoogleAuth": {
      "scopes": ["profile", "email"],
      "serverClientId": "ТВОЙ_WEB_CLIENT_ID.apps.googleusercontent.com",
      "androidClientId": "ТВОЙ_ANDROID_CLIENT_ID.apps.googleusercontent.com",
      "iosClientId": "ТВОЙ_IOS_CLIENT_ID.apps.googleusercontent.com"
    }
  }
}
